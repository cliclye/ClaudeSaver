# Upstream Anthropic API (proxy forwards here)
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# Bind address for Claude Code CLI — point ANTHROPIC_BASE_URL here
PORT=8766
HOST=127.0.0.1

# Optional: same key the CLI would use — if unset, proxy forwards the incoming x-api-key
# ANTHROPIC_API_KEY=

# Redis for shared cache (omit to use in-memory LRU)
# REDIS_URL=redis://127.0.0.1:6379

# Model ids for routing — defaults match Anthropic “Claude API ID” (see models docs)
# CHEAP_MODEL=claude-haiku-4-5-20251001
# SMART_MODEL=claude-sonnet-4-6
# PREMIUM_MODEL=claude-opus-4-7

# In-memory cache when REDIS_URL is unset
# CACHE_TTL_SECONDS=86400
# CACHE_MAX_ENTRIES=5000

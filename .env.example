# Upstream Anthropic API (proxy forwards /v1/messages here)
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# Bind address for the proxy — Claude Code: ANTHROPIC_BASE_URL=http://HOST:PORT
PORT=8766
HOST=127.0.0.1

# Optional: inject API key for Console users. If unset, the proxy forwards the client's
# own x-api-key or Authorization header. Leave UNSET for Pro/Max/Team subscription users.
# ANTHROPIC_API_KEY=

# Set to 1 to disable Haiku/Sonnet/Opus model swapping (helps some subscription-only setups)
# CLAUDE_SAVER_SKIP_MODEL_ROUTING=1

# Prompt compression is OFF by default because it rewrites user text (e.g. "please explain" → "EXPLAIN").
# Set to 1 to opt in.
# CLAUDE_SAVER_ENABLE_COMPRESSION=1

# Redis for shared cache (omit to use in-memory LRU)
# REDIS_URL=redis://127.0.0.1:6379

# Model ids for routing — defaults match Anthropic "Claude API ID" (see models docs)
# CHEAP_MODEL=claude-haiku-4-5-20251001
# SMART_MODEL=claude-sonnet-4-6
# PREMIUM_MODEL=claude-opus-4-7

# In-memory cache when REDIS_URL is unset
# CACHE_TTL_SECONDS=86400
# CACHE_MAX_ENTRIES=5000
